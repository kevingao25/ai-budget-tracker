generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Expense {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  category  String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
}

model BudgetConfig {
  id          String   @id
  totalBudget Float    @default(3000)
  updatedAt   DateTime @updatedAt
}

model Subscription {
  id              String   @id @default(cuid())
  name            String
  amount          Float
  billingCycle    String   @default("monthly")
  nextRenewalDate DateTime
  active          Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
}
